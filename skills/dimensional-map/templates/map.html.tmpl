// --- Per-domain explanation bar + radar blurb --------------------------------
// The explain bar lives at the top of the radar panel, mirroring the COMPARE
// pill row. Clicking a button swaps the right-side text block from the generic
// "Domain silhouettes" description to a per-axis explanation of why that
// instance sits where it does on the chart. State is `activeExplain` (model
// key, or null for default text). Bar is hidden entirely when DATA supplies
// no `perDomain` block — old maps stay unchanged.
function renderExplainBar() {
  const root = document.getElementById("radar-explain-bar");
  if (!root) return;
  if (!ACTIVE.perDomain || Object.keys(ACTIVE.perDomain).length === 0) {
    root.setAttribute("hidden", "hidden");
    root.innerHTML = "";
    return;
  }
  root.removeAttribute("hidden");
  const label = ACTIVE.meta.explainBarLabel ||
    (currentLang === "de" ? "Achsen-Erläuterung:" : "Per-axis explanation:");
  let html = `<span class="lbl">${label}</span>`;
  for (let i = 0; i < ACTIVE.models.length; i++) {
    const m = ACTIVE.models[i];
    const canon = DATA.models[i];
    if (!ACTIVE.perDomain[canon.key]) continue;  // skip if no per-domain content for this model
    const cls = (activeExplain === canon.key) ? "active" : "";
    html += `<button class="${cls}" data-key="${canon.key}" type="button" aria-pressed="${activeExplain === canon.key}"><span class="dot"></span>${m.name}</button>`;
  }
  root.innerHTML = html;
  root.querySelectorAll("button[data-key]").forEach(btn => {
    btn.addEventListener("click", () => {
      const key = btn.dataset.key;
      // Click active = deselect; click another = switch.
      activeExplain = (activeExplain === key) ? null : key;
      renderExplainBar();
      renderRadarBlurb();
    });
  });
}

// Render the right-side text block of the radar panel. Two modes:
//  - default (activeExplain === null): generic "Domain silhouettes" copy.
//  - per-domain (activeExplain set):   intro paragraph + N axis bullets,
//    each with the instance's chart position and a one-sentence reason.
// Hover on a bullet highlights the matching axis label on the radar (and the
// matching legend entry below the chart) — symmetric with radar-label hover.
function renderRadarBlurb() {
  const h = document.getElementById("radar-h");
  const p1 = document.getElementById("radar-p1");
  const lookH = document.getElementById("radar-look-h");
  const lookList = document.getElementById("radar-look-list");
  const pd = (ACTIVE.perDomain && activeExplain) ? ACTIVE.perDomain[activeExplain] : null;

  if (pd && activeExplain) {
    const canon = DATA.models.find(x => x.key === activeExplain);
    const idx = DATA.models.indexOf(canon);
    const m = (idx >= 0 && ACTIVE.models[idx]) ? ACTIVE.models[idx] : canon;
    const titleSuffix = ACTIVE.meta.explainSilhouetteSuffix ||
      (currentLang === "de" ? "warum diese Silhouette" : "why this silhouette");
    h.innerHTML = `<span class="domain-dot" style="background:${canon.color}"></span>${m.full || m.name} <span class="kind">${titleSuffix}</span>`;
    p1.innerHTML = pd.intro || "";
    lookH.textContent = pd.lookH || (currentLang === "de" ? "Achse für Achse:" : "Per-axis breakdown:");
    lookList.innerHTML = ACTIVE.axes.map((ax, i) => {
      const pos = (ax.pos && (activeExplain in ax.pos)) ? ax.pos[activeExplain] : null;
      const conf = (ax.confidence && ax.confidence[activeExplain]) ? ax.confidence[activeExplain] : "";
      const posLabel = (pos !== null) ? ` <span class="pos">(${pos.toFixed(2)}${conf})</span>` : "";
      const expl = (pd.axes && pd.axes[i]) ? pd.axes[i] : "";
      return `<li data-axis-index="${i}"><b>${ax.short}</b>${posLabel} — ${expl}</li>`;
    }).join("");
  } else {
    h.innerHTML = `${ACTIVE.meta.radarH} <span class="kind">${ACTIVE.meta.radarKind}</span>`;
    p1.innerHTML = ACTIVE.meta.radarP1;
    lookH.textContent = ACTIVE.meta.radarLookH;
    lookList.innerHTML = ACTIVE.meta.radarLook.map(s => `<li>${s}</li>`).join("");
  }

  // Bidirectional hover: bullet ↔ matching radar label + legend item.
  lookList.querySelectorAll("li[data-axis-index]").forEach(li => {
    const ix = li.getAttribute("data-axis-index");
    const setHL = (on) => {
      const r = document.querySelector(`.radar-axis-label[data-axis-index="${ix}"]`);
      if (r) r.classList.toggle("is-highlighted", on);
      const legendLi = document.querySelector(`#radar-axis-legend-list li[data-axis-index="${ix}"]`);
      if (legendLi) legendLi.classList.toggle("axis-li-highlighted", on);
    };
    li.addEventListener("mouseenter", () => setHL(true));
    li.addEventListener("mouseleave", () => setHL(false));
  });
}

// --- Axis-legend helpers ----------------------------------------------------
// Short one-line description for an axis. Uses `axis.tagline` if provided,
// otherwise falls back to the first sentence of `axis.blurb`.
function axisTagline(ax) {
  if (ax.tagline) return ax.tagline;
  const blurb = (ax.blurb || "").replace(/<[^>]+>/g, "");
  const m = blurb.match(/^[^.!?]+[.!?]/);
  return (m ? m[0] : blurb).trim();
}
function axisTaglinePlain(ax) { return axisTagline(ax).replace(/<[^>]+>/g, ""); }
function escSvg(s) {
  return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}
// Render the full axis name with the chart's short-label bolded inside it,
// so the eye snaps from the radar label to the legend entry instantly.
function fullNameWithBoldShort(name, short) {
  if (!name) return "";
  if (!short) return name;
  const re = new RegExp("(" + short.replace(/[.*+?^${}()|[\]\\]/g, "\\$&") + ")", "i");
  if (re.test(name)) return name.replace(re, "<b>$1</b>");
  return `<b>${short}</b> · ${name}`;
}
function renderAxisLegend() {
  const heading = ACTIVE.meta.axisLegendH || (currentLang === "de" ? "Achsen" : "Axes");
  const hint = ACTIVE.meta.axisLegendHint ||
    (currentLang === "de" ? "Labels im Chart antippen oder anhovern für Pole inline"
                          : "tap or hover labels in the chart for inline poles");
  document.getElementById("radar-axis-legend-h").innerHTML =
    `${heading} <span style="font-weight:400;letter-spacing:0;text-transform:none;color:var(--ink-dim);font-size:11px;margin-left:8px;">— ${hint}</span>`;
  const innerLabel = ACTIVE.meta.poleInnerLabel || (currentLang === "de" ? "Mitte" : "Centre");
  const outerLabel = ACTIVE.meta.poleOuterLabel || (currentLang === "de" ? "Rand"  : "Rim");
  const list = document.getElementById("radar-axis-legend-list");
  list.innerHTML = ACTIVE.axes.map((ax, i) => {
    const tag = axisTagline(ax);
    const lp = (ax.leftPole  && ax.leftPole.label)  || "";
    const rp = (ax.rightPole && ax.rightPole.label) || "";
    const poles = (lp || rp)
      ? `<div class="axis-poles"><span class="pole-inner"><em>${innerLabel}</em>${lp}</span><span class="sep">·</span><span class="pole-outer"><em>${outerLabel}</em>${rp}</span></div>`
      : "";
    const tipPlain = `${ax.name}${axisTaglinePlain(ax) ? " — " + axisTaglinePlain(ax) : ""}`;
    return `<li title="${tipPlain.replace(/"/g, "&quot;")}" data-axis-index="${i}">` +
             `<a href="#axis-${ax.id}"><div>${fullNameWithBoldShort(ax.name, ax.short)} — <span class="axis-tagline">${tag}</span></div></a>` +
             `${poles}` +
           `</li>`;
  }).join("");
  // Hover on a legend item highlights the corresponding label in the radar.
  // The radar SVG is re-rendered on every renderAll, so look the label up
  // per-event rather than caching a possibly-stale reference.
  list.querySelectorAll("li[data-axis-index]").forEach(li => {
    const idx = li.getAttribute("data-axis-index");
    const setHL = (on) => {
      const r = document.querySelector(`.radar-axis-label[data-axis-index="${idx}"]`);
      if (r) r.classList.toggle("is-highlighted", on);
    };
    li.addEventListener("mouseenter", () => setHL(true));
    li.addEventListener("mouseleave", () => setHL(false));
    li.querySelector("a")?.addEventListener("focus", () => setHL(true));
    li.querySelector("a")?.addEventListener("blur",  () => setHL(false));
  });
}

// Custom tooltips for radar axis labels — sidesteps the native <title> hover delay.
// Bound after every renderRadar() because renderRadar replaces the SVG's innerHTML.
// Touch path runs in parallel to the mouse/focus path: a tap toggles the tooltip
// sticky-open, a tap outside closes it. Desktop mouseenter/leave is unchanged.
function bindChartTooltips() {
  const tip = document.getElementById("chart-tooltip");
  const wrap = document.querySelector(".radar-svg-wrap");
  if (!tip || !wrap) return;
  const innerLabel = ACTIVE.meta.poleInnerLabel || (currentLang === "de" ? "Mitte" : "Centre");
  const outerLabel = ACTIVE.meta.poleOuterLabel || (currentLang === "de" ? "Rand"  : "Rim");
  function show(el) {
    const i = parseInt(el.getAttribute("data-axis-index"), 10);
    const ax = ACTIVE.axes[i];
    if (!ax) return;
    const lp = (ax.leftPole  && ax.leftPole.label)  || "";
    const rp = (ax.rightPole && ax.rightPole.label) || "";
    tip.innerHTML =
      `<b>${ax.name}</b>` +
      `<span class="tip-pole left"><em>${innerLabel}</em>${lp}</span>` +
      `<span class="tip-pole right"><em>${outerLabel}</em>${rp}</span>`;
    tip.setAttribute("data-on", "1");
    tip.setAttribute("aria-hidden", "false");
    // Position above the label, centred horizontally, clamped to the wrap box.
    const wrapRect = wrap.getBoundingClientRect();
    const elRect = el.getBoundingClientRect();
    const tipW = tip.offsetWidth, tipH = tip.offsetHeight;
    let left = elRect.left - wrapRect.left + elRect.width / 2 - tipW / 2;
    let top  = elRect.top  - wrapRect.top  - tipH - 8;
    if (left < 4) left = 4;
    if (left + tipW > wrapRect.width - 4) left = wrapRect.width - tipW - 4;
    if (top < 0) top = elRect.bottom - wrapRect.top + 8;       // flip below if no space above
    tip.style.left = left + "px";
    tip.style.top  = top  + "px";
  }
  function hide() {
    tip.removeAttribute("data-on");
    tip.setAttribute("aria-hidden", "true");
    tip.removeAttribute("data-touch-axis");
  }
  const hintEl = document.getElementById("radar-hint");
  function dismissHintOnce() {
    if (!hintEl || hintEl.hasAttribute("data-dismissed") || hintEl.hasAttribute("data-fade")) return;
    hintEl.setAttribute("data-fade", "1");
    setTimeout(() => { hintEl.setAttribute("data-dismissed", "1"); }, 260);
    try { localStorage.setItem("dm.radarHintDismissed", "1"); } catch (e) {}
  }
  // Reverse direction of the legend → label highlight already wired in
  // renderAxisLegend: hovering a radar label also lights up the matching
  // legend entry below the chart, plus the matching per-axis bullet on the
  // right (when a domain explanation is active).
  function setRelatedHL(el, on) {
    const idx = el.getAttribute("data-axis-index");
    const legendLi = document.querySelector(`#radar-axis-legend-list li[data-axis-index="${idx}"]`);
    if (legendLi) legendLi.classList.toggle("axis-li-highlighted", on);
    const bullet = document.querySelector(`#radar-look-list li[data-axis-index="${idx}"]`);
    if (bullet) bullet.classList.toggle("axis-li-highlighted", on);
  }
  document.querySelectorAll(".radar-axis-label").forEach(el => {
    el.addEventListener("mouseenter", () => { show(el); dismissHintOnce(); setRelatedHL(el, true); });
    el.addEventListener("mouseleave", () => { if (!tip.hasAttribute("data-touch-axis")) hide(); setRelatedHL(el, false); });
    el.addEventListener("focus", () => { show(el); dismissHintOnce(); setRelatedHL(el, true); });
    el.addEventListener("blur",  () => { if (!tip.hasAttribute("data-touch-axis")) hide(); setRelatedHL(el, false); });
    el.addEventListener("pointerdown", (e) => {
      if (!e.pointerType || e.pointerType === "mouse") return;  // desktop handled by mouseenter
      e.preventDefault();
      const idx = el.getAttribute("data-axis-index");
      if (tip.getAttribute("data-touch-axis") === idx) { hide(); setRelatedHL(el, false); return; }
      show(el);
      setRelatedHL(el, true);
      tip.setAttribute("data-touch-axis", idx);
    });
  });
  // Outside-tap dismiss (touch only). Registered once across rebinds.
  if (!bindChartTooltips._docBound) {
    bindChartTooltips._docBound = true;
    document.addEventListener("pointerdown", (e) => {
      if (!e.pointerType || e.pointerType === "mouse") return;
      const t = document.getElementById("chart-tooltip");
      if (!t || !t.hasAttribute("data-touch-axis")) return;
      if (e.target && e.target.closest && e.target.closest(".radar-axis-label")) return;
      t.removeAttribute("data-on");
      t.setAttribute("aria-hidden", "true");
      t.removeAttribute("data-touch-axis");
      // Clear any sticky-tap highlights from legend + bullets too.
      document.querySelectorAll(".axis-li-highlighted").forEach(li => li.classList.remove("axis-li-highlighted"));
    });
  }
}

function renderLegend() {
  const root = document.getElementById("legend");
  let html = `<span class="lbl">${ACTIVE.meta.legendLabel}</span>`;
  for (let i = 0; i < ACTIVE.models.length; i++) {
    const m = ACTIVE.models[i];
    const canon = DATA.models[i];
    const isTarget = !!canon.isTarget;
    const cls = `pill${isTarget ? " on target" : ""}${visible.has(canon.key) && !isTarget ? " on" : ""}`;
    html += `<span class="${cls}" data-key="${canon.key}"><span class="dot"></span>${m.full}</span>`;
  }
  root.innerHTML = html;
}

function densitySVG(peaks, idSuffix) {
  const stops = 21; const out = [];
  for (let i = 0; i <= stops; i++) {
    const x = i / stops; let y = 0;
    for (const p of peaks) { const d = (x - p.at) / p.w; y += p.h * Math.exp(-d * d * 2); }
    y = Math.min(1, y);
    const alpha = 0.05 + 0.55 * y;
    out.push(`<stop offset="${(x * 100).toFixed(1)}%" stop-color="rgba(180,200,230,${alpha.toFixed(3)})"/>`);
  }
  return `<svg width="100%" height="100%" preserveAspectRatio="none" viewBox="0 0 100 34" style="position:absolute;inset:0;border-radius:6px;">
    <defs><linearGradient id="g_${idSuffix}" x1="0" x2="1" y1="0" y2="0">${out.join("")}</linearGradient></defs>
    <rect x="0" y="0" width="100" height="34" fill="url(#g_${idSuffix})"/>
  </svg>`;
}

function renderDossier(axis) {
  const pole = (p, side) => `
    <div class="dossier-pole ${side}">
      <div class="dossier-head">
        <span class="dossier-label">${p.label}</span>
        <span class="dossier-exemplar"><b>${ACTIVE.meta.exemplarLabel}</b> ${p.exemplar}</span>
      </div>
      <ul class="dossier-bundle">${p.bundle.map(b => `<li>${b}</li>`).join("")}</ul>
      <div class="dossier-why"><b>${ACTIVE.meta.whyBundledLabel}</b> ${p.why}</div>
    </div>`;
  return `<div class="dossier">${pole(axis.leftPole, "left")}${pole(axis.rightPole, "right")}</div>`;
}

function renderAxes() {
  const root = document.getElementById("scales");
  root.innerHTML = "";
  for (let ai = 0; ai < ACTIVE.axes.length; ai++) {
    const axis = ACTIVE.axes[ai];
    const canonAxis = DATA.axes[ai];
    const el = document.createElement("div");
    el.className = "axis"; el.dataset.id = canonAxis.id;
    el.id = `axis-${canonAxis.id}`;

    const ordered = ACTIVE.models
      .map((m, i) => ({ ...m, key: DATA.models[i].key, isTarget: DATA.models[i].isTarget,
                        x: canonAxis.pos[DATA.models[i].key],
                        conf: (canonAxis.confidence || {})[DATA.models[i].key] || "" }))
      .filter(m => typeof m.x === "number")
      .sort((a, b) => a.x - b.x);

    // Marker side placement (4-tier collision detection):
    // target gets the innermost tier above; every other marker picks the first
    // tier whose nearest existing marker is at least OVERLAP away in x.
    // OVERLAP ≈ 0.11 covers typical label widths (~115px on a ~1100px bar).
    // The tier order is interleaved (above1, below1, above2, below2) so the
    // map stays vertically compact when the data isn't crowded.
    const OVERLAP = 0.11;
    const targetEntry = ordered.find(om => om.isTarget);
    const tiers = { above1: [], above2: [], below1: [], below2: [] };
    const tierOrder = ["above1", "below1", "above2", "below2"];
    const sideByKey = {};
    if (targetEntry) {
      tiers.above1.push(targetEntry.x);
      sideByKey[targetEntry.key] = "above1";
    }
    const nearestDist = (arr, x) =>
      arr.reduce((m, v) => Math.min(m, Math.abs(v - x)), Infinity);
    for (const om of ordered) {
      if (om.isTarget) continue;
      let chosen = null, bestDist = -1;
      for (const t of tierOrder) {
        const d = nearestDist(tiers[t], om.x);
        if (d >= OVERLAP) { chosen = t; break; }
        if (d > bestDist) { bestDist = d; chosen = t; } // remember least crowded as fallback
      }
      tiers[chosen].push(om.x);
      sideByKey[om.key] = chosen;
    }

    const markers = ordered.map(m => {
      const side = sideByKey[m.key];
      const hidden = m.isTarget ? false : !visible.has(m.key);
      const targetCls = m.isTarget ? " target" : "";
      const conf = m.conf ? `<span class="conf">${m.conf}</span>` : "";
      const title = `${m.full}${m.conf ? ` [${m.conf}]` : ""} — ${(m.x).toFixed(2)}`;
      return `<div class="marker lbl-${side}${targetCls}" data-key="${m.key}" data-hidden="${hidden ? 1 : 0}" style="left:${(m.x * 100).toFixed(2)}%" title="${title}">
                <span class="label">${m.name}${conf}</span>
              </div>`;
    }).join("");

    el.innerHTML = `
      <div class="axis-head">
        <div class="axis-name"><span class="axis-num">${ai + 1}<span class="axis-num-total"> / ${ACTIVE.axes.length}</span></span>${axis.name}<span class="kind">${axis.kind}</span></div>
      </div>
      <p class="axis-blurb">${axis.blurb}</p>
      <div class="scale-wrap">
        <div class="density">${densitySVG(canonAxis.densityPeaks, canonAxis.id)}</div>
        <div class="scale-bar"></div>
        <div class="endpoints"><span>${axis.leftPole.label}</span><span>${axis.rightPole.label}</span></div>
        ${markers}
      </div>
      ${renderDossier(axis)}
      <div class="axis-foot"><b>${ACTIVE.meta.targetLabel}</b> ${axis.foot}</div>
    `;
    root.appendChild(el);
  }
}

function refreshMarkers() {
  document.querySelectorAll(".marker").forEach(el => {
    const key = el.dataset.key;
    const m = DATA.models.find(x => x.key === key);
    if (!m) return;
    if (m.isTarget) { el.dataset.hidden = "0"; return; }
    el.dataset.hidden = visible.has(key) ? "0" : "1";
  });
}

const RADAR_CX = 190, RADAR_CY = 175, RADAR_R = 110;
function radarPoint(i, frac, N) {
  const angle = (-90 + i * (360 / N)) * Math.PI / 180;
  return { x: RADAR_CX + RADAR_R * frac * Math.cos(angle),
           y: RADAR_CY + RADAR_R * frac * Math.sin(angle) };
}
function renderRadar() {
  const svg = document.getElementById("radar-svg");
  const N = ACTIVE.axes.length;
  let html = "";
  for (const frac of [0.25, 0.5, 0.75, 1.0]) {
    const pts = [];
    for (let i = 0; i < N; i++) { const p = radarPoint(i, frac, N); pts.push(`${p.x.toFixed(1)},${p.y.toFixed(1)}`); }
    html += `<polygon class="radar-grid" points="${pts.join(" ")}" opacity="${0.4 + 0.15 * frac}"/>`;
  }
  for (let i = 0; i < N; i++) {
    const outer = radarPoint(i, 1.0, N);
    html += `<line class="radar-axis-line" x1="${RADAR_CX}" y1="${RADAR_CY}" x2="${outer.x.toFixed(1)}" y2="${outer.y.toFixed(1)}"/>`;
    const lbl = radarPoint(i, 1.16, N);
    let anchor = "middle";
    if (lbl.x > RADAR_CX + 4) anchor = "start";
    else if (lbl.x < RADAR_CX - 4) anchor = "end";
    let baseline = "middle";
    if (lbl.y > RADAR_CY + 4) baseline = "hanging";
    else if (lbl.y < RADAR_CY - 4) baseline = "auto";
    const ax_i = ACTIVE.axes[i];
    html += `<text class="radar-axis-label" data-axis-index="${i}" x="${lbl.x.toFixed(1)}" y="${lbl.y.toFixed(1)}" text-anchor="${anchor}" dominant-baseline="${baseline}">${escSvg(ax_i.short)}</text>`;
  }
  const t1 = radarPoint(0, 0.5, N);
  html += `<text class="radar-tick-label" x="${(t1.x + 4).toFixed(1)}" y="${t1.y.toFixed(1)}" dominant-baseline="middle">0.5</text>`;
  const t2 = radarPoint(0, 1.0, N);
  html += `<text class="radar-tick-label" x="${(t2.x + 4).toFixed(1)}" y="${t2.y.toFixed(1)}" dominant-baseline="middle">1.0</text>`;
  const order = DATA.models.slice().map((m, i) => ({ canon: m, idx: i }))
    .sort((a, b) => (a.canon.isTarget ? 1 : 0) - (b.canon.isTarget ? 1 : 0));
  for (const { canon, idx } of order) {
    const pts = [];
    for (let i = 0; i < N; i++) {
      const v = DATA.axes[i].pos[canon.key];
      if (typeof v !== "number") continue;
      const p = radarPoint(i, v, N);
      pts.push(`${p.x.toFixed(1)},${p.y.toFixed(1)}`);
    }
    if (pts.length !== N) continue;
    const hidden = canon.isTarget ? false : !visible.has(canon.key);
    const cls = `radar-poly${canon.isTarget ? " target" : ""}`;
    html += `<polygon class="${cls}" data-key="${canon.key}" data-hidden="${hidden ? 1 : 0}" points="${pts.join(" ")}"><title>${ACTIVE.models[idx].full}</title></polygon>`;
  }
  svg.innerHTML = html;
}
function refreshRadar() {
  document.querySelectorAll(".radar-poly").forEach(el => {
    const key = el.dataset.key;
    const m = DATA.models.find(x => x.key === key);
    if (!m) return;
    if (m.isTarget) { el.dataset.hidden = "0"; return; }
    el.dataset.hidden = visible.has(key) ? "0" : "1";
  });
}

function renderCovar() {
  const root = document.getElementById("covar");
  let html = `<h2>${ACTIVE.meta.covarH}</h2>
    <p class="intro">${ACTIVE.meta.covarIntro}</p>
    <div class="covar-grid">`;
  for (const c of ACTIVE.covariations) {
    const strengthCls = (c.strength || "").toLowerCase();
    html += `
      <div class="covar-card">
        <div class="pair"><span>${c.a} <em>↔</em> ${c.b}</span><span class="strength ${strengthCls}">${c.strength || ""}</span></div>
        <p class="mech">${c.mechanism}</p>
        <p class="ex"><b>${ACTIVE.meta.exampleLabel}</b> ${c.example}</p>
      </div>`;
  }
  html += "</div>";
  root.innerHTML = html;
}

// Render the sources section at the bottom of the page. Sources are grouped
// twice — once by axis they informed, once by instance — so a reader who's
// skeptical about a specific claim can jump directly to the relevant citation.
// Same source may appear under multiple groups; that's intentional (each
// occurrence anchors the citation to a specific use site).
//
// Sources without `uses` (or with `uses.general: true`) appear under a
// "General references" group. If DATA.sources is empty/missing, the entire
// section is hidden.
function renderSources() {
  const root = document.getElementById("sources");
  if (!root) return;
  const sources = (ACTIVE.sources && ACTIVE.sources.length) ? ACTIVE.sources : [];
  if (!sources.length) {
    root.setAttribute("hidden", "hidden");
    root.innerHTML = "";
    return;
  }
  root.removeAttribute("hidden");

  const heading = (ACTIVE.meta && ACTIVE.meta.sourcesH) ||
    (currentLang === "de" ? "Quellen" : "Sources");
  const intro = (ACTIVE.meta && ACTIVE.meta.sourcesIntro) || (currentLang === "de"
    ? "Belege gruppiert nach den Achsen und Beispielen, für die sie verwendet wurden. Dieselbe Quelle erscheint unter jeder Stelle, an der sie eine Aussage trägt — kein Sammelverzeichnis am Ende, sondern eine Brücke zum jeweiligen Argument."
    : "References grouped by the axes and instances they informed. The same source appears under each place it supports — not a bibliography dump, but a bridge back to the argument in the map.");
  const axesH    = (ACTIVE.meta && ACTIVE.meta.sourcesAxesH)    || (currentLang === "de" ? "Nach Achse"      : "By axis");
  const modelsH  = (ACTIVE.meta && ACTIVE.meta.sourcesModelsH)  || (currentLang === "de" ? "Nach Beispiel"   : "By instance");
  const generalH = (ACTIVE.meta && ACTIVE.meta.sourcesGeneralH) || (currentLang === "de" ? "Allgemein"       : "General references");
  const axisKind = (ACTIVE.meta && ACTIVE.meta.sourcesAxisKind) || (currentLang === "de" ? "Achse"           : "Axis");
  const modelKind= (ACTIVE.meta && ACTIVE.meta.sourcesModelKind)|| (currentLang === "de" ? "Beispiel"        : "Instance");

  function srcLi(s) {
    const titleInner = s.url
      ? `<a href="${s.url}" target="_blank" rel="noopener">${s.title}</a>`
      : s.title;
    const note = s.note ? `<span class="src-note">— ${s.note}</span>` : "";
    return `<li><span class="src-title">${titleInner}</span> ${note}</li>`;
  }

  // Group 1: by axis. Order follows ACTIVE.axes so the layout mirrors the chart.
  let axisGroupsHtml = "";
  for (const ax of ACTIVE.axes) {
    const hits = sources.filter(s => s.uses && s.uses.axes && s.uses.axes.includes(ax.id));
    if (!hits.length) continue;
    axisGroupsHtml += `
      <div class="src-group" data-axis-id="${ax.id}">
        <div class="group-label">
          <span class="group-dot"></span>${ax.name}<span class="group-kind">${axisKind}</span>
        </div>
        <ul class="src-list">${hits.map(srcLi).join("")}</ul>
      </div>`;
  }

  // Group 2: by instance. Order follows ACTIVE.models.
  let modelGroupsHtml = "";
  for (let i = 0; i < ACTIVE.models.length; i++) {
    const m = ACTIVE.models[i];
    const canon = DATA.models[i];
    const hits = sources.filter(s => s.uses && s.uses.models && s.uses.models.includes(canon.key));
    if (!hits.length) continue;
    modelGroupsHtml += `
      <div class="src-group" data-key="${canon.key}">
        <div class="group-label">
          <span class="group-dot" style="background:${canon.color}"></span>${m.full || m.name}<span class="group-kind">${modelKind}</span>
        </div>
        <ul class="src-list">${hits.map(srcLi).join("")}</ul>
      </div>`;
  }

  // Group 3: general references — no `uses`, or `uses.general === true`.
  const generals = sources.filter(s => !s.uses || s.uses.general === true ||
    (!(s.uses.axes && s.uses.axes.length) && !(s.uses.models && s.uses.models.length)));
  let generalHtml = "";
  if (generals.length) {
    generalHtml = `
      <div class="src-section">
        <h3>${generalH}</h3>
        <div class="src-group">
          <ul class="src-list">${generals.map(srcLi).join("")}</ul>
        </div>
      </div>`;
  }

  root.innerHTML = `
    <h2>${heading}</h2>
    ${intro ? `<p class="sources-intro">${intro}</p>` : ""}
    ${axisGroupsHtml ? `<div class="src-section"><h3>${axesH}</h3>${axisGroupsHtml}</div>` : ""}
    ${modelGroupsHtml ? `<div class="src-section"><h3>${modelsH}</h3>${modelGroupsHtml}</div>` : ""}
    ${generalHtml}
  `;
}

// ---- Wiring ---------------------------------------------------------------

function renderAll() {
  ACTIVE = buildActive(currentLang);
  renderHeaderAndMeta();
  renderLegend();
  renderExplainBar();
  renderAxes();
  renderRadar();
  bindChartTooltips();  // re-bind after each renderRadar (SVG innerHTML was replaced)
  renderAxisLegend();
  renderCovar();
  renderSources();
  syncLangPills();
  bindPills();  // pills are re-rendered each time, so we re-bind
}

function syncLangPills() {
  document.querySelectorAll(".lang-pill").forEach(el => {
    el.classList.toggle("active", el.dataset.lang === currentLang);
  });
}

function bindLangToggle() {
  document.querySelectorAll(".lang-pill").forEach(el => {
    el.addEventListener("click", () => {
      const lang = el.dataset.lang;
      if (lang !== "en" && lang !== "de") return;
      if (lang === currentLang) return;
      currentLang = lang;
      setLangCookie(lang);
      renderAll();
    });
  });
}

function bindPills() {
  document.querySelectorAll(".legend .pill").forEach(pill => {
    const key = pill.dataset.key;
    const m = DATA.models.find(x => x.key === key);
    if (!m || m.isTarget) return;
    pill.addEventListener("click", () => {
      let turnedOn = false;
      if (visible.has(key)) { visible.delete(key); pill.classList.remove("on"); }
      else                  { visible.add(key);    pill.classList.add("on"); turnedOn = true; }
      refreshMarkers();
      refreshRadar();
      // Last-toggled-ON pill auto-selects its explanation (most-recent wins).
      // Turning a pill OFF does not change the active explanation — the user
      // may keep reading it, and can switch manually via the explain-bar.
      // No-op if DATA has no perDomain block for this model.
      if (turnedOn && ACTIVE.perDomain && ACTIVE.perDomain[key]) {
        activeExplain = key;
        renderExplainBar();
        renderRadarBlurb();
      }
    });
  });
}

bindLangToggle();
renderAll();

</script>
</body>
</html>
