// ---- Language detection + active-data merge --------------------------------

function detectLang() {
  let pref = null;
  try { pref = (document.cookie.match(/(?:^|;\s*)dt_lang_pref=([^;]+)/) || [])[1]; } catch (e) {}
  if (pref === "en" || pref === "de") return pref;
  const langs = (navigator.languages || [navigator.language || ""]);
  if (langs.some(l => /^de\b/i.test(l))) return "de";
  return "en";
}
function setLangCookie(lang) {
  try { document.cookie = "dt_lang_pref=" + lang + "; path=/; max-age=31536000; samesite=lax"; } catch (e) {}
}

// Merge canonical (top-level) DATA with the active language overrides.
// Missing keys in the override fall back to canonical, so partial translations work.
function buildActive(lang) {
  function mergePerDomain(canon, overlay) {
    if (!canon && !overlay) return undefined;
    const out = {};
    const keys = new Set([...Object.keys(canon || {}), ...Object.keys(overlay || {})]);
    for (const k of keys) {
      const c = (canon && canon[k]) || {};
      const o = (overlay && overlay[k]) || {};
      out[k] = {
        ...c, ...o,
        axes: (o.axes && o.axes.length) ? o.axes : c.axes,
      };
    }
    return out;
  }
  function mergeSources(canon, overlay) {
    if (!canon || !canon.length) return overlay && overlay.length ? overlay : (canon || []);
    if (!overlay || !overlay.length) return canon;
    // Overlays merged by id (or by index if no id). Allows partial translation —
    // e.g. translate just `title`/`note` and leave `uses`/`url` from canonical.
    const byId = {};
    canon.forEach((s, i) => { byId[s.id || `__idx_${i}`] = i; });
    return canon.map((s, i) => {
      const key = s.id || `__idx_${i}`;
      const ov = overlay.find(o => (o.id || `__idx_${overlay.indexOf(o)}`) === key);
      return ov ? { ...s, ...ov, uses: ov.uses || s.uses } : s;
    });
  }
  if (lang !== "de" || !DATA.de) {
    return { meta: DATA.meta, models: DATA.models, axes: DATA.axes, covariations: DATA.covariations,
             perDomain: DATA.perDomain, sources: DATA.sources };
  }
  const o = DATA.de;
  return {
    meta: { ...DATA.meta, ...(o.meta || {}) },
    models: DATA.models.map((m, i) => ({ ...m, ...((o.models && o.models[i]) || {}) })),
    axes: DATA.axes.map((a, i) => {
      const oa = (o.axes && o.axes[i]) || {};
      return {
        ...a, ...oa,
        leftPole:  { ...a.leftPole,  ...(oa.leftPole  || {}) },
        rightPole: { ...a.rightPole, ...(oa.rightPole || {}) },
      };
    }),
    covariations: DATA.covariations.map((c, i) =>
      ({ ...c, ...((o.covariations && o.covariations[i]) || {}) })),
    perDomain: mergePerDomain(DATA.perDomain, o.perDomain),
    sources: mergeSources(DATA.sources, o.sources),
  };
}

let currentLang = detectLang();
let ACTIVE = buildActive(currentLang);

