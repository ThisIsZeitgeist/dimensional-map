<!DOCTYPE html>
<!--
  dimensional-map renderer — self-contained, no build step.
  Schema lives in `const DATA = { ... }` block below the marker.
  All visible strings live under DATA.meta / DATA.axes / DATA.models / DATA.covariations.
  Optional bilingual mode: provide `DATA.de = { meta, models, axes, covariations }`
  with the same shape as the top level (or partial overrides). The renderer
  picks `de` when navigator language is German or the user clicks the DE pill.
-->
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title id="page-title">Dimensional map</title>
<style>
  :root {
    --bg: #0f1115;
    --panel: #161a22;
    --panel-2: #1d222c;
    --ink: #e8ecf1;
    --ink-mute: #9aa3b2;
    --ink-dim: #6b7484;
    --accent: #79b8ff;
    --accent-2: #ffb86b;
    --accent-3: #b392f0;
    --accent-4: #85e89d;
    --warn: #f97583;
    --rule: #2a3140;
    --rule-2: #1f2530;
    --target: #f97583;
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  html, body { background: var(--bg); color: var(--ink); margin: 0; }
  body {
    font: 15px/1.55 -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", system-ui, sans-serif;
    max-width: 1180px; margin: 0 auto; padding: 40px 28px 96px;
  }
  header { margin-bottom: 10px; }
  header .skill-tag {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.10em;
    color: var(--accent); border: 1px solid rgba(121,184,255,0.3);
    padding: 4px 12px; border-radius: 999px;
    margin-bottom: 12px; font-weight: 600;
    text-decoration: none;
    transition: background-color 120ms, border-color 120ms, color 120ms;
  }
  header a.skill-tag[href]:hover {
    background-color: rgba(121,184,255,0.10);
    border-color: rgba(121,184,255,0.55);
    color: var(--ink);
  }
  header a.skill-tag:not([href]) { cursor: default; }
  header h1 {
    font-size: 30px; margin: 0 0 8px; letter-spacing: -0.005em;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-weight: 600;
  }
  header .sub { color: var(--ink-mute); font-size: 15px; max-width: 820px; line-height: 1.55; }
  header .sub b { color: var(--ink); font-weight: 600; }
  header .sub em { color: var(--ink); font-style: normal; font-weight: 600; }
  header .crossref {
    margin: 10px 0 0; font-size: 13px; color: var(--ink-dim);
    padding: 8px 12px; background: var(--panel-2);
    border: 1px solid var(--rule-2); border-left: 3px solid var(--accent-2);
    border-radius: 0 6px 6px 0;
    max-width: 820px;
  }
  header .crossref a {
    color: var(--accent-2); text-decoration: none; font-weight: 600;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  }
  header .crossref a:hover { text-decoration: underline; }
  header .crossref em { color: var(--ink); font-style: normal; }

  /* Top-right fixed actions: GitHub link + language toggle, sticky on scroll */
  .header-actions {
    position: fixed; top: 14px; right: 14px; z-index: 100;
    display: flex; gap: 8px; align-items: center;
  }
  .repo-button {
    background: rgba(22,26,34,0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 4px 11px 4px 9px;
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; letter-spacing: 0.04em; font-weight: 600;
    color: var(--ink-mute); text-decoration: none;
    transition: background-color 120ms, color 120ms, border-color 120ms;
  }
  .repo-button:hover { color: var(--ink); border-color: var(--ink-dim); }
  .repo-button svg { width: 14px; height: 14px; fill: currentColor; display: block; }
  .lang-toggle {
    background: rgba(22,26,34,0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 3px;
    display: flex; gap: 1px;
    font-size: 12px; letter-spacing: 0.06em; font-weight: 600;
  }
  .lang-pill {
    padding: 4px 11px; border-radius: 999px;
    color: var(--ink-mute); cursor: pointer; user-select: none;
    transition: background 120ms, color 120ms;
  }
  .lang-pill:hover { color: var(--ink); }
  .lang-pill.active { background: var(--panel-2); color: var(--ink); }

  /* Top-of-page summary (bullets, not prose) */
  .meta {
    background: var(--panel); border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 22px 26px 24px; margin: 18px 0 28px;
  }
  .meta strong { color: var(--ink); } .meta b { color: var(--ink); font-weight: 600; }
  .meta em { color: var(--ink); font-style: normal; }
  .meta .meta-h {
    font-size: 12px; text-transform: uppercase; letter-spacing: 0.09em;
    color: var(--ink-dim); margin: 0 0 14px; font-weight: 700;
  }
  .meta ul.bullet-list {
    margin: 0; padding: 0; list-style: none;
    display: flex; flex-direction: column; gap: 9px;
  }
  .meta ul.bullet-list li {
    color: var(--ink-mute); font-size: 14px; line-height: 1.55;
    padding-left: 22px; position: relative;
  }
  .meta ul.bullet-list li::before {
    content: ""; position: absolute;
    left: 4px; top: 9px; width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent);
  }
  .meta ul.bullet-list li:nth-child(2)::before { background: var(--accent-3); }
  .meta ul.bullet-list li:nth-child(3)::before { background: var(--accent-2); }
  .meta ul.bullet-list li:nth-child(4)::before { background: var(--accent-4); }
  .meta ul.bullet-list li:nth-child(5)::before { background: var(--warn); }
  .meta .meta-why {
    margin: 14px 0 0; padding-top: 14px;
    border-top: 1px solid var(--rule-2);
    color: var(--ink-mute); font-size: 13px; line-height: 1.6;
  }
  .meta .meta-why code {
    background: rgba(255,255,255,0.04); border: 1px solid var(--rule-2);
    border-radius: 4px; padding: 1px 5px; font-size: 12px; color: var(--accent-2);
  }

  .legend {
    display: flex; flex-wrap: wrap; gap: 8px 6px;
    align-items: center; margin: 16px 0 6px;
  }
  .legend .lbl {
    font-size: 12px; color: var(--ink-dim); margin-right: 8px;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; border-radius: 999px;
    border: 1px solid var(--rule); background: var(--panel);
    color: var(--ink-mute); font-size: 12px;
    cursor: pointer; user-select: none;
    transition: background 120ms, color 120ms, border-color 120ms;
  }
  .pill:hover { color: var(--ink); border-color: var(--rule-2); }
  .pill .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--ink-mute); box-shadow: 0 0 0 2px var(--panel); }
  .pill.on { background: var(--panel-2); color: var(--ink); border-color: var(--ink-dim); }
  .pill.target { color: var(--target); border-color: rgba(249,117,131,0.35); }
  .pill.target .dot { background: var(--target); }

  /* Radar */
  .radar-section {
    background: var(--panel); border: 1px solid var(--rule); border-radius: 10px;
    padding: 18px 22px; margin: 22px 0 6px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .radar-section .radar-top { display: flex; gap: 28px; align-items: center; }
  .radar-section .radar-svg-wrap { flex: 0 0 auto; width: 420px; height: 380px; position: relative; }
  .radar-section .radar-svg-wrap > svg { width: 100%; height: 100%; display: block; overflow: visible; }
  .radar-section .radar-blurb { flex: 1; min-width: 0; }
  .radar-section h2 { margin: 0 0 6px; font-size: 17px; letter-spacing: -0.005em; }
  .radar-section h2 .kind { font-size: 11px; font-weight: 500; color: var(--ink-dim); margin-left: 8px; text-transform: uppercase; letter-spacing: 0.07em; }
  .radar-section p { font-size: 13px; color: var(--ink-mute); margin: 0 0 10px; line-height: 1.55; }
  .radar-section p b { color: var(--ink); font-weight: 600; }
  .radar-blurb ul { margin: 6px 0 0; padding-left: 18px; font-size: 13px; color: var(--ink-mute); }
  .radar-blurb ul li { margin: 3px 0; } .radar-blurb ul li b { color: var(--ink); font-weight: 600; }

  .radar-grid { fill: none; stroke: var(--rule); stroke-width: 1; }
  .radar-axis-line { stroke: var(--rule); stroke-width: 1; opacity: 0.65; }
  .radar-axis-label { fill: var(--ink-dim); font-size: 10.5px; letter-spacing: 0.04em; text-transform: uppercase; cursor: help; transition: fill 120ms; }
  .radar-axis-label:hover,
  .radar-axis-label.is-highlighted { fill: var(--ink); font-weight: 600; }
  .radar-tick-label { fill: var(--ink-dim); font-size: 9px; opacity: 0.55; }
  .radar-poly { fill-opacity: 0.12; stroke-width: 1.5; transition: fill-opacity 120ms; cursor: default; }
  .radar-poly:hover { fill-opacity: 0.32; }
  .radar-poly.target { fill-opacity: 0.20; stroke-width: 2; }
  .radar-poly.target:hover { fill-opacity: 0.38; }
  .radar-poly[data-hidden="1"] { display: none; }

  /* Compact axis legend below the radar — bold short-name matches the chart label, one line per axis. */
  .radar-axis-legend {
    border-top: 1px solid var(--rule-2);
    padding-top: 12px;
  }
  .radar-axis-legend .legend-h {
    font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.09em;
    color: var(--ink-dim); font-weight: 600; margin: 0 0 8px;
  }
  .radar-axis-legend ul {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(420px, 1fr));
    gap: 6px 28px;
    margin: 0; padding: 0; list-style: none;
  }
  .radar-axis-legend li {
    font-size: 12px; color: var(--ink-mute); line-height: 1.5;
    padding-left: 12px; position: relative;
    /* Allow wrapping; clamp to 2 lines as a safety net for very long taglines */
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .radar-axis-legend li::before {
    content: ""; position: absolute; left: 2px; top: 8px;
    width: 4px; height: 4px; border-radius: 50%; background: var(--ink-dim);
  }
  .radar-axis-legend li b { color: var(--ink); font-weight: 600; }
  .radar-axis-legend li .axis-fullname { color: var(--ink-mute); }
  .radar-axis-legend li .axis-tagline { color: var(--ink-dim); }
  .radar-axis-legend li > a {
    color: inherit; text-decoration: none; display: block;
    border-radius: 3px; transition: background 120ms;
  }
  .radar-axis-legend li > a:hover { background: rgba(255,255,255,0.04); }
  .radar-axis-legend li > a:hover .axis-tagline { color: var(--ink-mute); }
  .radar-axis-legend li > a:focus-visible {
    outline: 1px solid var(--rule-2); outline-offset: 2px;
  }
  .radar-axis-legend li .axis-poles {
    display: block; font-size: 11px; color: var(--ink-dim); margin-top: 2px;
  }
  .radar-axis-legend li .axis-poles em {
    font-style: normal; font-size: 9.5px; text-transform: uppercase;
    letter-spacing: 0.06em; font-weight: 600; margin-right: 4px;
  }
  .radar-axis-legend li .axis-poles .pole-inner em { color: var(--accent); }
  .radar-axis-legend li .axis-poles .pole-outer em { color: var(--accent-2); }
  .radar-axis-legend li .axis-poles .sep { color: var(--ink-mute); margin: 0 7px; }

  /* Bidirectional axis highlight: radar label ⇄ legend entry / per-axis bullet.
     Hover on any of the three lights up the other two. */
  .radar-axis-legend li.axis-li-highlighted > a {
    background: rgba(255,255,255,0.06);
  }
  .radar-axis-legend li.axis-li-highlighted b { color: var(--ink); }
  .radar-axis-legend li.axis-li-highlighted .axis-tagline { color: var(--ink-mute); }
  .radar-blurb #radar-look-list li.axis-li-highlighted {
    background: rgba(255,255,255,0.05);
    border-radius: 4px;
  }
  .radar-blurb #radar-look-list li.axis-li-highlighted b { color: var(--ink); }

  /* Per-domain explanation bar — buttons mirror the COMPARE pills. Sits inside
     the radar-section, above the chart + text block. Only rendered when DATA
     supplies a `perDomain` block; otherwise hidden so old maps keep working. */
  .radar-section .radar-explain-bar {
    display: flex; flex-wrap: wrap; gap: 6px;
    align-items: center;
    margin: 0 0 14px;
    padding: 8px 10px;
    background: var(--panel-2);
    border: 1px solid var(--rule-2);
    border-radius: 8px;
  }
  .radar-section .radar-explain-bar[hidden] { display: none; }
  .radar-section .radar-explain-bar .lbl {
    font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--ink-dim); margin-right: 4px; font-weight: 600;
  }
  .radar-section .radar-explain-bar button {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-mute);
    font: 12px/1.2 -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", system-ui, sans-serif;
    padding: 4px 10px;
    border-radius: 999px;
    cursor: pointer;
    display: inline-flex; align-items: center; gap: 6px;
    transition: background 120ms, border-color 120ms, color 120ms;
  }
  .radar-section .radar-explain-bar button .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--ink-dim);
    flex: 0 0 auto;
  }
  .radar-section .radar-explain-bar button:hover {
    color: var(--ink); border-color: var(--ink-dim);
  }
  .radar-section .radar-explain-bar button.active {
    background: rgba(255,255,255,0.06);
    color: var(--ink);
  }

  /* Coloured dot + position chip inside the radar blurb when a domain explanation is active */
  .radar-blurb .domain-dot {
    display: inline-block;
    width: 11px; height: 11px;
    border-radius: 50%;
    margin-right: 8px;
    vertical-align: -1px;
    background: var(--ink-dim);
  }
  .radar-blurb #radar-look-list li .pos {
    color: var(--ink-dim); font-size: 11px; font-weight: 500;
    margin-left: 1px;
  }

  /* Instant custom tooltip for chart axis labels (no native-title delay) */
  .chart-tooltip {
    position: absolute; pointer-events: none; z-index: 50;
    background: var(--panel-2); border: 1px solid var(--rule);
    border-radius: 6px; padding: 7px 10px;
    font-size: 11.5px; line-height: 1.45; color: var(--ink);
    max-width: 280px; box-shadow: 0 6px 18px rgba(0,0,0,0.45);
    opacity: 0; transform: translateY(2px);
    transition: opacity 80ms, transform 80ms;
    display: none;
  }
  .chart-tooltip[data-on="1"] { opacity: 1; transform: translateY(0); display: block; }
  .chart-tooltip b {
    display: block; color: var(--ink); font-weight: 600;
    font-size: 12.5px; text-transform: uppercase; letter-spacing: 0.05em;
    margin-bottom: 3px;
  }
  .chart-tooltip .tip-pole { display: block; margin-top: 4px; font-size: 11.5px; line-height: 1.4; color: var(--ink); }
  .chart-tooltip .tip-pole em { display: inline-block; min-width: 54px; font-style: normal; font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600; margin-right: 4px; vertical-align: baseline; }
  .chart-tooltip .tip-pole.left  em { color: var(--accent); }
  .chart-tooltip .tip-pole.right em { color: var(--accent-2); }

  /* Discovery hint inside the radar box. Visible by default on all devices;
     on hover-capable devices, dismissed after the first label hover and
     remembered in localStorage. On touch devices it stays. */
  .radar-hint {
    display: inline-flex;
    position: absolute; top: 6px; left: 6px; z-index: 4;
    align-items: center; gap: 6px;
    font-size: 10.5px; line-height: 1;
    color: var(--ink-mute); letter-spacing: 0.02em;
    background: var(--panel-2); border: 1px solid var(--rule); border-radius: 999px;
    padding: 4px 10px 4px 8px;
    pointer-events: none;
    transition: opacity 220ms ease, transform 220ms ease;
  }
  .radar-hint svg { width: 12px; height: 12px; opacity: 0.85; flex: 0 0 auto; }
  .radar-hint[data-fade="1"] { opacity: 0; transform: translateY(-2px); }
  .radar-hint[data-dismissed="1"] { display: none; }

  @media (max-width: 880px) {
    .radar-section .radar-top { flex-direction: column; align-items: stretch; gap: 14px; }
    .radar-section .radar-svg-wrap { width: 100%; max-width: 420px; height: auto; aspect-ratio: 420 / 380; margin: 0 auto; }
    .radar-axis-legend ul { grid-template-columns: 1fr; }
  }

  /* Per-axis scales */
  .scales { display: flex; flex-direction: column; gap: 10px; margin-top: 22px; }
  .axis {
    background: var(--panel); border: 1px solid var(--rule); border-radius: 10px;
    padding: 16px 20px 22px;
    scroll-margin-top: 16px;
  }
  .axis-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .axis-name { font-size: 15px; font-weight: 600; color: var(--ink); letter-spacing: -0.005em; }
  .axis-name .axis-num {
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: 11px; font-weight: 600; letter-spacing: 0.05em;
    color: var(--accent);
    border: 1px solid rgba(121,184,255,0.30);
    border-radius: 4px; padding: 2px 7px;
    margin-right: 11px; vertical-align: 2px;
  }
  .axis-name .axis-num .axis-num-total { color: var(--ink-dim); font-weight: 500; }
  .axis-name .kind { font-size: 11px; font-weight: 500; color: var(--ink-dim); margin-left: 8px; text-transform: uppercase; letter-spacing: 0.07em; }
  .axis-blurb { color: var(--ink-mute); font-size: 13px; max-width: 820px; margin: 0 0 12px; }
  .axis-blurb em { color: var(--ink); font-style: normal; }

  .scale-wrap { position: relative; height: 130px; margin: 0 6px; }
  .scale-bar { position: absolute; left: 0; right: 0; top: 46px; height: 6px; border-radius: 3px;
    background: linear-gradient(to right, rgba(121,184,255,0.12), rgba(255,184,107,0.12));
    border: 1px solid var(--rule); }
  .density { position: absolute; left: 0; right: 0; top: 30px; height: 34px; border-radius: 6px; pointer-events: none; opacity: 0.45; filter: blur(0.5px); }
  .endpoints { position: absolute; left: 0; right: 0; top: 112px; display: flex; justify-content: space-between;
    font-size: 11px; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.07em; pointer-events: none; }
  .endpoints span:first-child { color: var(--accent); }
  .endpoints span:last-child  { color: var(--accent-2); }

  .marker {
    position: absolute; top: 41px; transform: translateX(-50%);
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--ink-mute); border: 2px solid var(--bg);
    box-shadow: 0 0 0 1px var(--rule); cursor: default;
    transition: transform 120ms, opacity 120ms;
  }
  .marker.target { width: 18px; height: 18px; top: 39px; background: var(--target);
    box-shadow: 0 0 0 1px rgba(249,117,131,0.4), 0 0 14px rgba(249,117,131,0.35); z-index: 5; }
  .marker[data-hidden="1"] { display: none; }
  .marker .label { position: absolute; left: 50%; transform: translateX(-50%);
    white-space: nowrap; font-size: 11px; color: var(--ink-mute); pointer-events: none; }
  .marker.target .label { color: var(--target); font-weight: 600; }
  .marker.lbl-above .label,
  .marker.lbl-above1 .label { bottom: 24px; }
  .marker.lbl-above2 .label { bottom: 44px; }
  .marker.lbl-below .label,
  .marker.lbl-below1 .label { top: 24px; }
  .marker.lbl-below2 .label { top: 44px; }
  .marker .label .conf { font-size: 9px; color: var(--ink-dim); margin-left: 2px; opacity: 0.65; }

  /* Endpoint dossier */
  .dossier {
    display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
    margin: 8px 0 10px; padding: 12px 14px;
    background: var(--panel-2); border: 1px solid var(--rule-2); border-radius: 8px;
  }
  .dossier-pole { font-size: 12.5px; line-height: 1.55; }
  .dossier-head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; margin-bottom: 6px; }
  .dossier-label { font-weight: 600; font-size: 13px; }
  .dossier-pole.left  .dossier-label { color: var(--accent); }
  .dossier-pole.right .dossier-label { color: var(--accent-2); }
  .dossier-exemplar { font-size: 11px; color: var(--ink-dim); font-style: italic; white-space: nowrap; }
  .dossier-exemplar b { color: var(--ink-mute); font-style: normal; font-weight: 600; }
  .dossier-bundle {
    display: flex; flex-wrap: wrap; gap: 4px 6px;
    margin: 4px 0 6px; padding: 0; list-style: none;
  }
  .dossier-bundle li {
    background: rgba(255,255,255,0.025); border: 1px solid var(--rule-2); border-radius: 4px;
    padding: 2px 7px; font-size: 11px; color: var(--ink-mute);
  }
  .dossier-pole.left .dossier-bundle li  { border-color: rgba(121,184,255,0.18); }
  .dossier-pole.right .dossier-bundle li { border-color: rgba(255,184,107,0.18); }
  .dossier-why { font-size: 11.5px; color: var(--ink-mute); }
  .dossier-why b { color: var(--ink-dim); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; font-size: 10px; margin-right: 4px; }

  @media (max-width: 700px) {
    .dossier { grid-template-columns: 1fr; }
  }

  .axis-foot { margin-top: 10px; color: var(--ink-dim); font-size: 12px; line-height: 1.5; }
  .axis-foot b { color: var(--ink-mute); font-weight: 600; }

  /* Co-variation panel */
  .covar { background: var(--panel); border: 1px solid var(--rule); border-radius: 10px; padding: 18px 22px; margin-top: 28px; }
  .covar h2 { font-size: 17px; margin: 0 0 6px; letter-spacing: -0.005em; }
  .covar p.intro { font-size: 13px; color: var(--ink-mute); margin: 0 0 14px; max-width: 820px; }
  .covar p.intro b { color: var(--ink); font-weight: 600; }
  .covar-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px 18px; }
  .covar-card { background: var(--panel-2); border: 1px solid var(--rule-2); border-radius: 8px; padding: 12px 14px; font-size: 13px; }
  .covar-card .pair { color: var(--accent); font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  .covar-card .pair em { color: var(--ink-dim); font-style: normal; margin: 0 4px; }
  .covar-card .pair .strength { font-size: 10px; padding: 1px 6px; border-radius: 999px; border: 1px solid var(--rule-2); color: var(--ink-dim); letter-spacing: 0.04em; }
  .covar-card .pair .strength.tight, .covar-card .pair .strength.eng   { color: var(--target); border-color: rgba(249,117,131,0.35); }
  .covar-card .pair .strength.loose, .covar-card .pair .strength.locker { color: var(--accent-4); border-color: rgba(133,232,157,0.35); }
  .covar-card .mech { color: var(--ink-mute); margin: 0 0 6px; line-height: 1.5; }
  .covar-card .mech b { color: var(--ink); font-weight: 600; }
  .covar-card .ex { color: var(--ink-dim); font-size: 12px; font-style: italic; }
  .covar-card .ex b { color: var(--ink-mute); font-style: normal; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; font-size: 10px; margin-right: 4px; }

  /* Sources section — sources grouped by the axes / instances they informed.
     Auto-rendered when DATA.sources is non-empty; hidden otherwise. */
  .sources { margin-top: 28px; }
  .sources[hidden] { display: none; }
  .sources > h2 { font-size: 17px; margin: 0 0 6px; letter-spacing: -0.005em; }
  .sources > .sources-intro { font-size: 13px; color: var(--ink-mute); margin: 0 0 16px; max-width: 820px; }
  .sources > .sources-intro b { color: var(--ink); font-weight: 600; }
  .sources .src-section { margin-bottom: 18px; }
  .sources .src-section > h3 {
    font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.10em;
    color: var(--ink-dim); font-weight: 600; margin: 0 0 8px;
  }
  .sources .src-group {
    background: var(--panel); border: 1px solid var(--rule);
    border-radius: 8px; padding: 10px 14px;
    margin-bottom: 6px;
  }
  .sources .src-group > .group-label {
    font-size: 12.5px; font-weight: 600; color: var(--ink);
    margin: 0 0 6px; display: flex; align-items: center; gap: 8px;
  }
  .sources .src-group > .group-label .group-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--ink-dim); flex: 0 0 auto;
  }
  .sources .src-group > .group-label .group-kind {
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.07em;
    color: var(--ink-dim); font-weight: 500; margin-left: 6px;
  }
  .sources .src-list { list-style: none; padding: 0; margin: 0; }
  .sources .src-list > li {
    padding: 4px 0 4px 16px; position: relative;
    font-size: 12.5px; color: var(--ink-mute); line-height: 1.5;
  }
  .sources .src-list > li::before {
    content: "·"; position: absolute; left: 4px; top: 4px; color: var(--ink-dim);
  }
  .sources .src-list .src-title { color: var(--ink); font-weight: 500; }
  .sources .src-list .src-title a { color: var(--accent); text-decoration: none; }
  .sources .src-list .src-title a:hover { text-decoration: underline; }
  .sources .src-list .src-note { color: var(--ink-mute); margin-left: 4px; }

  .footer-note { margin-top: 30px; color: var(--ink-dim); font-size: 12px; line-height: 1.6; border-top: 1px solid var(--rule-2); padding-top: 16px; }
  .footer-note b { color: var(--ink-mute); }

  @media (max-width: 760px) {
    body { padding: 60px 14px 60px; }
    .marker .label { font-size: 10px; }
    .axis { padding: 14px 14px 22px; }
  }
</style>
