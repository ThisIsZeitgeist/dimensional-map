const visible = new Set();
DATA.models.forEach(m => { if (m.isTarget) visible.add(m.key); });

// Which domain's axis-by-axis explanation is currently displayed in the radar blurb.
// null = default "Domain silhouettes" text. Auto-set on pill ON; manually
// overridable via the explain-bar buttons.
let activeExplain = null;

// Inject per-model CSS rules from canonical DATA (color is language-independent).
(function injectModelStyles() {
  const css = DATA.models.map(m => `
    .marker[data-key="${m.key}"]    { background: ${m.color}; }
    .pill[data-key="${m.key}"] .dot { background: ${m.color}; }
    .radar-explain-bar button[data-key="${m.key}"] .dot { background: ${m.color}; }
    .radar-explain-bar button[data-key="${m.key}"].active { border-color: ${m.color}; }
    .radar-poly[data-key="${m.key}"]{ fill: ${m.color}; stroke: ${m.color}; }
  `).join("\n");
  const style = document.createElement("style");
  style.textContent = css;
  document.head.appendChild(style);
})();

